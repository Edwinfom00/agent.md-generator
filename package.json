{
  "name": "agent-md-generator-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun run --cwd packages/web dev",
    "build:web": "bun run --cwd packages/web build",
    "build:cli": "bun run --cwd packages/cli build",
    "cli": "bun run --cwd packages/cli dev",
    "test:cli": "bun run --cwd packages/cli test:local",
    "lint": "bun run --cwd packages/web lint"
  }
}
